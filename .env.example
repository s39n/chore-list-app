# Copy to .env (or set these in Dockhand) and adjust.

# Host port the board is reachable on, e.g. http://<nas-ip>:8080/
CHORE_PORT=3000

# Where points/balances are stored on the NAS (host path or named volume).
# Examples:
#   /volume1/docker/chore-board/data   (Synology)
#   /mnt/user/appdata/chore-board      (Unraid)
CHORE_DATA=./data

# PIN for the parent approval page (/approve.html) — CHANGE THIS.
PARENT_PIN=1234

# Oikos backend the proxy forwards /api/* requests to.
OIKOS_HOST=10.0.0.202
OIKOS_PORT=3008
